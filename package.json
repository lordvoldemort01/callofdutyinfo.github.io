{
  "name": "callofdutyinfo.github.io",
  "version": "1.0.0",
  "description": "Call of Duty Info Site",
  "main": "index.html",
  "scripts": {
    "start": "browser-sync start --server . --files '**/*'",
    "lint": "npx htmlhint '**/*.html' && npx stylelint '**/*.css'",
    "format": "npx prettier --write '**/*.{html,css,js}'"
  },
  "devDependencies": {
    "browser-sync": "^3.0.0",
    "htmlhint": "^1.1.4",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
